                      "source":  "#ifndef SPRITE_JOY_SID_BUMPS_C_GAME_H\n#define SPRITE_JOY_SID_BUMPS_C_GAME_H\n\nvoid copy_charset(void);\nvoid copy_sprites(void);\n\n#endif"
