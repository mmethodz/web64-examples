                      "kind":  "source",
                      "source":  "/*\n * Web64 IDE Example\n * Name: Sprite Joy SID Bumps C\n * Description: C-first version of the sprite, joystick, SID, and bumps charset demo.\n */\n\n#include \u003cstdint.h\u003e\n#include \"game.h\"\n\n#define BORDER 0xd020\n#define BACKGROUND 0xd021\n#define VIC_MEMORY 0xd018\n#define SCREEN_RAM 0x0400\n#define COLOR_RAM 0xd800\n#define SPR0_X 0xd000\n#define SPR0_Y 0xd001\n#define SPR_MSB 0xd010\n#define SPR_ENABLE 0xd015\n#define SPR_MC 0xd01c\n#define SPR_PTR0 0x07f8\n#define SPR_MC0 0xd025\n#define SPR_MC1 0xd026\n#define SPR_COLOR0 0xd027\n#define JOY2 0xdc00\n#define CIA1_DDRA 0xdc02\n#define CIA1_DDRB 0xdc03\n#define SID 0xd400\n#define SPRITE_PTR 0xc0\n\nuint16_t x_pos = 160;\nuint8_t y_pos = 112;\nuint8_t x_vel = 0;\nuint8_t y_vel = 0;\nuint8_t joy_now = 0xff;\nuint8_t frame = 0;\nuint8_t anim_delay = 0;\nuint8_t sid_delay = 0;\nuint8_t sid_step = 0;\nuint8_t scene_phase = 0;\n\nvoid poke(uint16_t address, uint8_t value) { *(uint8_t*)address = value; }\nuint8_t peek(uint16_t address) { return *(uint8_t*)address; }\n\nvoid wait_frame(void) {\n    asm volatile(\n        \"wait_not_f8_c:\\n\"\n        \"    lda $d012\\n\"\n        \"    cmp #$f8\\n\"\n        \"    beq wait_not_f8_c\\n\"\n        \"wait_f8_c:\\n\"\n        \"    lda $d012\\n\"\n        \"    cmp #$f8\\n\"\n        \"    bne wait_f8_c\\n\"\n    );\n}\n\nvoid setup_video(void) {\n    poke(CIA1_DDRA, 0);\n    poke(CIA1_DDRB, 0);\n    poke(BORDER, 0);\n    poke(BACKGROUND, 0);\n    poke(VIC_MEMORY, 0x18);\n}\n\nvoid setup_sprite(void) {\n    poke(SPR_PTR0, SPRITE_PTR);\n    poke(SPR_ENABLE, 1);\n    poke(SPR_MC, 1);\n    poke(SPR_MC0, 5);\n    poke(SPR_MC1, 11);\n    poke(SPR_COLOR0, 1);\n}\n\nvoid read_joystick(void) { joy_now = peek(JOY2); }\n\nvoid update_x_velocity(void) {\n    if (!(joy_now \u0026 4)) {\n        if (x_vel != 0xfc) { x_vel = x_vel - 1; }\n        return;\n    }\n    if (!(joy_now \u0026 8)) {\n        if (x_vel != 4) { x_vel = x_vel + 1; }\n        return;\n    }\n    if (x_vel == 0) { return; }\n    if (x_vel \u0026 0x80) { x_vel = x_vel + 1; }\n    else { x_vel = x_vel - 1; }\n}\n\nvoid update_y_velocity(void) {\n    if (!(joy_now \u0026 1)) {\n        if (y_vel != 0xfd) { y_vel = y_vel - 1; }\n        return;\n    }\n    if (!(joy_now \u0026 2)) {\n        if (y_vel != 3) { y_vel = y_vel + 1; }\n        return;\n    }\n    if (y_vel == 0) { return; }\n    if (y_vel \u0026 0x80) { y_vel = y_vel + 1; }\n    else { y_vel = y_vel - 1; }\n}\n\nvoid apply_motion(void) {\n    uint8_t speed;\n    if (x_vel \u0026 0x80) {\n        speed = (uint8_t)(0 - x_vel);\n        if (x_pos \u003c speed) { x_pos = 320 - (speed - x_pos); }\n        else { x_pos = x_pos - speed; }\n    } else {\n        x_pos = x_pos + x_vel;\n        if (x_pos \u003e= 320) { x_pos = x_pos - 320; }\n    }\n\n    if (y_vel \u0026 0x80) {\n        speed = (uint8_t)(0 - y_vel);\n        if (y_pos \u003c= (50 + speed)) { y_pos = 50; y_vel = 0; }\n        else { y_pos = y_pos - speed; }\n    } else {\n        y_pos = y_pos + y_vel;\n        if (y_pos \u003e= 219) { y_pos = 219; y_vel = 0; }\n    }\n}\n\nvoid position_sprite(void) {\n    poke(SPR0_X, (uint8_t)x_pos);\n    poke(SPR0_Y, y_pos);\n    if (x_pos \u003e= 256) { poke(SPR_MSB, peek(SPR_MSB) | 1); }\n    else { poke(SPR_MSB, peek(SPR_MSB) \u0026 0xfe); }\n    if (!(joy_now \u0026 16)) { poke(SPR_COLOR0, 2); }\n    else { poke(SPR_COLOR0, 1); }\n}\n\nvoid animate_ghost(void) {\n    if ((x_vel | y_vel) == 0) {\n        frame = 0;\n        poke(SPR_PTR0, SPRITE_PTR);\n        return;\n    }\n    anim_delay = anim_delay + 1;\n    if (anim_delay \u003c 5) { return; }\n    anim_delay = 0;\n    frame = frame + 1;\n    if (frame \u003e= 4) { frame = 0; }\n    poke(SPR_PTR0, SPRITE_PTR + frame);\n}\n\nuint8_t shade_char(uint8_t index) {\n    if (index \u003c 8) { return 0x1a; }\n    return (uint8_t)(0x1f - index);\n}\n\nuint8_t wave_value(uint8_t x) {\n    if (x \u003c 16) { return x; }\n    if (x \u003c 32) { return (uint8_t)(31 - x); }\n    return (uint8_t)(x - 32);\n}\n\nvoid clear_screen(void) {\n    uint16_t i = 0;\n    while (i \u003c 1000) {\n        poke(SCREEN_RAM + i, 0);\n        i = i + 1;\n    }\n}\n\nvoid paint_scene(void) {\n    uint8_t x = 0;\n    while (x \u003c 40) {\n        poke(COLOR_RAM + 0x0028 + x, 6);\n        poke(COLOR_RAM + 0x0050 + x, 6);\n        poke(COLOR_RAM + 0x0370 + x, 6);\n        poke(COLOR_RAM + 0x0078 + x, 14);\n        poke(COLOR_RAM + 0x00a0 + x, 14);\n        poke(COLOR_RAM + 0x0348 + x, 14);\n        poke(COLOR_RAM + 0x00c8 + x, 3);\n        poke(COLOR_RAM + 0x02f8 + x, 3);\n        poke(COLOR_RAM + 0x01e0 + x, 1);\n        poke(COLOR_RAM + 0x0208 + x, 1);\n        x = x + 1;\n    }\n}\n\nvoid pulse_scene(void) {\n    uint8_t x = 0;\n    uint8_t index;\n    scene_phase = scene_phase + 1;\n    if (scene_phase \u0026 3) { return; }\n    while (x \u003c 40) {\n        index = (uint8_t)((x + scene_phase) \u0026 0x1f);\n        poke(SCREEN_RAM + 0x0028 + x, shade_char(index));\n        index = (uint8_t)(((scene_phase \u003e\u003e 1) + wave_value(x)) \u0026 0x1f);\n        poke(SCREEN_RAM + 0x0370 + x, shade_char(index));\n        x = x + 1;\n    }\n}\n\nuint8_t note_value(uint8_t table, uint8_t step) {\n    uint8_t s = step \u0026 15;\n    if (table == 0) {\n        if (s == 0) return 0x25; if (s == 1) return 0x6b; if (s == 2) return 0xb6; if (s == 3) return 0x0d;\n        if (s == 4) return 0x6b; if (s == 5) return 0xd5; if (s == 6) return 0x4b; if (s == 7) return 0xd1;\n        if (s == 8) return 0x25; if (s == 9) return 0xd1; if (s == 10) return 0x4b; if (s == 11) return 0xd5;\n        if (s == 12) return 0x6b; if (s == 13) return 0x0d; if (s == 14) return 0xb6; return 0x6b;\n    }\n    if (table == 1) {\n        if (s == 0) return 0x11; if (s == 1) return 0x12; if (s == 2) return 0x13; if (s == 3) return 0x15;\n        if (s == 4) return 0x16; if (s == 5) return 0x17; if (s == 6) return 0x19; if (s == 7) return 0x1a;\n        if (s == 8) return 0x1c; if (s == 9) return 0x1a; if (s == 10) return 0x19; if (s == 11) return 0x17;\n        if (s == 12) return 0x16; if (s == 13) return 0x15; if (s == 14) return 0x13; return 0x12;\n    }\n    if (table == 2) {\n        if (s \u003c 2) return 0x12; if (s \u003c 4) return 0x35; if (s \u003c 6) return 0x12; if (s \u003c 8) return 0x46;\n        if (s \u003c 10) return 0x25; if (s \u003c 12) return 0x58; if (s \u003c 14) return 0x25; return 0x46;\n    }\n    if (table == 3) {\n        if (s \u003c 2) return 0x08; if (s \u003c 4) return 0x09; if (s \u003c 6) return 0x08; if (s \u003c 8) return 0x0a;\n        if (s \u003c 10) return 0x09; if (s \u003c 12) return 0x0b; if (s \u003c 14) return 0x09; return 0x0a;\n    }\n    if (table == 4) {\n        if (s \u003c 2) return 0xb6; if (s \u003c 4) return 0x0d; if (s \u003c 6) return 0x4b; if (s \u003c 8) return 0xd1;\n        if (s \u003c 10) return 0x6b; if (s \u003c 12) return 0x25; if (s \u003c 14) return 0xd5; return 0x6b;\n    }\n    if (s \u003c 2) return 0x13; if (s \u003c 4) return 0x15; if (s \u003c 6) return 0x19; if (s \u003c 8) return 0x1a;\n    if (s \u003c 10) return 0x16; if (s \u003c 12) return 0x1c; if (s \u003c 14) return 0x17; return 0x12;\n}\n\nvoid sid_init(void) {\n    uint8_t i = 0;\n    while (i \u003c 25) { poke(SID + i, 0); i = i + 1; }\n    poke(SID + 0x18, 0x0f);\n    poke(SID + 0x05, 0x09); poke(SID + 0x06, 0x86);\n    poke(SID + 0x0c, 0x08); poke(SID + 0x0d, 0x86);\n    poke(SID + 0x13, 0x08); poke(SID + 0x14, 0xa8);\n    poke(SID + 0x04, 0x11); poke(SID + 0x0b, 0x21); poke(SID + 0x12, 0x41);\n}\n\nvoid play_sid(void) {\n    sid_delay = sid_delay + 1;\n    if (sid_delay \u003c 8) { return; }\n    sid_delay = 0;\n    sid_step = sid_step + 1;\n    poke(SID + 0x00, note_value(0, sid_step)); poke(SID + 0x01, note_value(1, sid_step));\n    poke(SID + 0x07, note_value(2, sid_step)); poke(SID + 0x08, note_value(3, sid_step));\n    poke(SID + 0x0e, note_value(4, sid_step)); poke(SID + 0x0f, note_value(5, sid_step));\n}\n\nvoid main(void) {\n    setup_video();\n    copy_charset();\n    copy_sprites();\n    clear_screen();\n    paint_scene();\n    sid_init();\n    setup_sprite();\n\n    while (1) {\n        wait_frame();\n        play_sid();\n        read_joystick();\n        update_x_velocity();\n        update_y_velocity();\n        apply_motion();\n        animate_ghost();\n        position_sprite();\n        pulse_scene();\n    }\n}"
                  },
