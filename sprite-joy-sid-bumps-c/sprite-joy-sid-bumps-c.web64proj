                      "path":  "asset_copy.asm",
                      "name":  "asset_copy.asm",
                      "kind":  "source",
                      "source":  "; Web64 IDE Example\n; Name: Sprite Joy SID Bumps C Asset Copy\n; Description: Mandatory assembly bridge for binary asset labels used by the C program.\n\n_copy_charset:\n    ldx #$00\ncopy_char_loop_c:\n    lda bumps_chars+$0000,x\n    sta $2000,x\n    lda bumps_chars+$0100,x\n    sta $2100,x\n    lda bumps_chars+$0200,x\n    sta $2200,x\n    lda bumps_chars+$0300,x\n    sta $2300,x\n    lda bumps_chars+$0400,x\n    sta $2400,x\n    lda bumps_chars+$0500,x\n    sta $2500,x\n    lda bumps_chars+$0600,x\n    sta $2600,x\n    lda bumps_chars+$0700,x\n    sta $2700,x\n    inx\n    bne copy_char_loop_c\n    rts\n\n_copy_sprites:\n    ldx #$00\ncopy_sprite_loop_c:\n    lda c_joy_sprites,x\n    sta $3000,x\n    inx\n    bne copy_sprite_loop_c\n    rts\n\n.incbin c_joy_sprites, \"assets/sprites/c-joy.spr\"\n.include \"assets/sprites/c-joy.inc\"\n.incbin bumps_chars, \"assets/chars/bumps.chr\"\n.include \"assets/chars/bumps.inc\""
