    "fileName": "sprite-joy-sid-bumps.asm",
    "origin": "$c000",
    "source": "; Web64 IDE Example\n; Name: Sprite Joy SID Bumps\n; Animated ghost, joystick acceleration, 16-bit X wrap at 320, bumps charset backdrop, and SID tune.\n\n* = $c000\n    jmp init\n\nBORDER=$d020\nBACKGROUND=$d021\nVIC_MEMORY=$d018\nRASTER=$d012\nSCREEN_RAM=$0400\nCOLOR_RAM=$d800\nSPR0_X=$d000\nSPR0_Y=$d001\nSPR_MSB=$d010\nSPR_ENABLE=$d015\nSPR_MC=$d01c\nSPR_PTR0=$07f8\nSPR_MC0=$d025\nSPR_MC1=$d026\nSPR_COLOR0=$d027\nJOY2=$dc00\nCIA1_DDRA=$dc02\nCIA1_DDRB=$dc03\nSID=$d400\nSPRITE_PTR=$c0\n\ninit:\n    sei\n    lda #$00\n    sta CIA1_DDRA\n    sta CIA1_DDRB\n    sta BORDER\n    sta BACKGROUND\n    lda #%00011000\n    sta VIC_MEMORY\n    jsr copy_charset\n    jsr copy_sprites\n    jsr clear_screen\n    jsr paint_scene\n    jsr sid_init\n    jsr sprite_init\n\nmainloop:\n    jsr wait_frame\n    jsr play_sid\n    jsr read_joy\n    jsr update_x_velocity\n    jsr update_y_velocity\n    jsr apply_motion\n    jsr animate_ghost\n    jsr position_sprite\n    jsr pulse_scene\n    jmp mainloop\n\nwait_frame:\nwait_not_f8:\n    lda RASTER\n    cmp #$f8\n    beq wait_not_f8\nwait_f8:\n    lda RASTER\n    cmp #$f8\n    bne wait_f8\n    rts\n\nsprite_init:\n    lda #SPRITE_PTR\n    sta SPR_PTR0\n    lda #%00000001\n    sta SPR_ENABLE\n    sta SPR_MC\n    lda #c_joy_multicolor_1\n    sta SPR_MC0\n    lda #c_joy_multicolor_2\n    sta SPR_MC1\n    lda #c_joy_sprite_color\n    sta SPR_COLOR0\n    rts\n\nread_joy:\n    lda JOY2\n    sta joy_now\n    rts\n\nupdate_x_velocity:\n    lda joy_now\n    and #%00000100\n    bne not_left\n    lda x_vel\n    cmp #$fc\n    beq x_done\n    dec x_vel\n    jmp x_done\nnot_left:\n    lda joy_now\n    and #%00001000\n    bne no_x_input\n    lda x_vel\n    cmp #$04\n    beq x_done\n    inc x_vel\n    jmp x_done\nno_x_input:\n    lda x_vel\n    beq x_done\n    bmi friction_right\n    dec x_vel\n    jmp x_done\nfriction_right:\n    inc x_vel\nx_done:\n    rts\n\nupdate_y_velocity:\n    lda joy_now\n    and #%00000001\n    bne not_up\n    lda y_vel\n    cmp #$fd\n    beq y_done\n    dec y_vel\n    jmp y_done\nnot_up:\n    lda joy_now\n    and #%00000010\n    bne no_y_input\n    lda y_vel\n    cmp #$03\n    beq y_done\n    inc y_vel\n    jmp y_done\nno_y_input:\n    lda y_vel\n    beq y_done\n    bmi y_friction_down\n    dec y_vel\n    jmp y_done\ny_friction_down:\n    inc y_vel\ny_done:\n    rts\n\napply_motion:\n    lda x_vel\n    clc\n    adc x_lo\n    sta x_lo\n    lda x_vel\n    bpl add_x_positive\n    lda x_hi\n    adc #$ff\n    sta x_hi\n    jmp wrap_x\nadd_x_positive:\n    lda x_hi\n    adc #$00\n    sta x_hi\nwrap_x:\n    lda x_hi\n    cmp #$ff\n    bne check_right_wrap\n    lda x_lo\n    clc\n    adc #$40\n    sta x_lo\n    lda x_hi\n    adc #$01\n    sta x_hi\n    jmp apply_y\ncheck_right_wrap:\n    lda x_hi\n    beq apply_y\n    cmp #$01\n    bne subtract_320\n    lda x_lo\n    cmp #$40\n    bcc apply_y\nsubtract_320:\n    lda x_lo\n    sec\n    sbc #$40\n    sta x_lo\n    lda x_hi\n    sbc #$01\n    sta x_hi\napply_y:\n    lda y_vel\n    clc\n    adc y_pos\n    sta y_pos\n    cmp #$32\n    bcs check_y_bottom\n    lda #$32\n    sta y_pos\n    lda #0\n    sta y_vel\n    rts\ncheck_y_bottom:\n    cmp #$db\n    bcc motion_done\n    lda #$db\n    sta y_pos\n    lda #0\n    sta y_vel\nmotion_done:\n    rts\n\nposition_sprite:\n    lda x_lo\n    sta SPR0_X\n    lda y_pos\n    sta SPR0_Y\n    lda x_hi\n    and #$01\n    beq clear_msb\n    lda SPR_MSB\n    ora #%00000001\n    sta SPR_MSB\n    jmp color_sprite\nclear_msb:\n    lda SPR_MSB\n    and #%11111110\n    sta SPR_MSB\ncolor_sprite:\n    lda joy_now\n    and #%00010000\n    bne no_fire\n    lda #$02\n    sta SPR_COLOR0\n    rts\nno_fire:\n    lda #c_joy_sprite_color\n    sta SPR_COLOR0\n    rts\n\nanimate_ghost:\n    lda x_vel\n    ora y_vel\n    bne moving_anim\n    lda #0\n    sta frame\n    lda #SPRITE_PTR\n    sta SPR_PTR0\n    rts\nmoving_anim:\n    inc anim_delay\n    lda anim_delay\n    cmp #5\n    bcc anim_done\n    lda #0\n    sta anim_delay\n    inc frame\n    lda frame\n    cmp #4\n    bcc frame_ok\n    lda #0\n    sta frame\nframe_ok:\n    lda #SPRITE_PTR\n    clc\n    adc frame\n    sta SPR_PTR0\nanim_done:\n    rts\n\nsid_init:\n    ldx #$18\n    lda #0\nsid_clear:\n    sta SID,x\n    dex\n    bpl sid_clear\n    lda #$0f\n    sta SID+$18\n    lda #$09\n    sta SID+$05\n    lda #$86\n    sta SID+$06\n    lda #$08\n    sta SID+$0c\n    lda #$86\n    sta SID+$0d\n    lda #$08\n    sta SID+$13\n    lda #$a8\n    sta SID+$14\n    lda #$11\n    sta SID+$04\n    lda #$21\n    sta SID+$0b\n    lda #$41\n    sta SID+$12\n    rts\n\nplay_sid:\n    inc sid_delay\n    lda sid_delay\n    cmp #8\n    bcc sid_done\n    lda #0\n    sta sid_delay\n    inc sid_step\n    lda sid_step\n    and #$0f\n    tax\n    lda lead_lo,x\n    sta SID+$00\n    lda lead_hi,x\n    sta SID+$01\n    lda bass_lo,x\n    sta SID+$07\n    lda bass_hi,x\n    sta SID+$08\n    lda chord_lo,x\n    sta SID+$0e\n    lda chord_hi,x\n    sta SID+$0f\nsid_done:\n    rts\n\nclear_screen:\n    ldx #0\n    lda #0\nclear_loop:\n    sta SCREEN_RAM+$0000,x\n    sta SCREEN_RAM+$0100,x\n    sta SCREEN_RAM+$0200,x\n    sta SCREEN_RAM+$02e8,x\n    inx\n    bne clear_loop\n    rts\n\npaint_scene:\n    ldx #$27\npaint_loop:\n    lda #$06\n    sta COLOR_RAM+$0028,x\n    sta COLOR_RAM+$0050,x\n    sta COLOR_RAM+$0370,x\n    lda #$0e\n    sta COLOR_RAM+$0078,x\n    sta COLOR_RAM+$00a0,x\n    sta COLOR_RAM+$0348,x\n    lda #$03\n    sta COLOR_RAM+$00c8,x\n    sta COLOR_RAM+$02f8,x\n    lda #$01\n    sta COLOR_RAM+$01e0,x\n    sta COLOR_RAM+$0208,x\n    dex\n    bpl paint_loop\n    rts\n\npulse_scene:\n    inc scene_phase\n    lda scene_phase\n    and #$03\n    bne pulse_done\n    ldx #$27\npulse_loop:\n    txa\n    clc\n    adc scene_phase\n    and #$1f\n    tay\n    lda shade_chars,y\n    sta SCREEN_RAM+$0028,x\n    lda scene_phase\n    lsr\n    clc\n    adc wave_x,x\n    and #$1f\n    tay\n    lda shade_chars,y\n    sta SCREEN_RAM+$0370,x\n    dex\n    bpl pulse_loop\npulse_done:\n    rts\n\ncopy_charset:\n    ldx #$00\ncopy_char_loop:\n    lda bumps_chars+$0000,x\n    sta $2000,x\n    lda bumps_chars+$0100,x\n    sta $2100,x\n    lda bumps_chars+$0200,x\n    sta $2200,x\n    lda bumps_chars+$0300,x\n    sta $2300,x\n    lda bumps_chars+$0400,x\n    sta $2400,x\n    lda bumps_chars+$0500,x\n    sta $2500,x\n    lda bumps_chars+$0600,x\n    sta $2600,x\n    lda bumps_chars+$0700,x\n    sta $2700,x\n    inx\n    bne copy_char_loop\n    rts\n\ncopy_sprites:\n    ldx #0\ncopy_sprite_loop:\n    lda c_joy_sprites,x\n    sta $3000,x\n    inx\n    bne copy_sprite_loop\n    rts\n\nx_lo: .byte 160\nx_hi: .byte 0\ny_pos: .byte 112\nx_vel: .byte 0\ny_vel: .byte 0\njoy_now: .byte $ff\nframe: .byte 0\nanim_delay: .byte 0\nsid_delay: .byte 0\nsid_step: .byte 0\nscene_phase: .byte 0\n\nlead_lo: .byte $25,$6b,$b6,$0d,$6b,$d5,$4b,$d1,$25,$d1,$4b,$d5,$6b,$0d,$b6,$6b\nlead_hi: .byte $11,$12,$13,$15,$16,$17,$19,$1a,$1c,$1a,$19,$17,$16,$15,$13,$12\nbass_lo: .byte $12,$12,$35,$35,$12,$12,$46,$46,$25,$25,$58,$58,$25,$25,$46,$46\nbass_hi: .byte $08,$08,$09,$09,$08,$08,$0a,$0a,$09,$09,$0b,$0b,$09,$09,$0a,$0a\nchord_lo:.byte $b6,$b6,$0d,$0d,$4b,$4b,$d1,$d1,$6b,$6b,$25,$25,$d5,$d5,$6b,$6b\nchord_hi:.byte $13,$13,$15,$15,$19,$19,$1a,$1a,$16,$16,$1c,$1c,$17,$17,$12,$12\n\nshade_chars:\n    .byte $1a,$1a,$1a,$1a,$1a,$1a,$1a,$1a\n    .byte $17,$16,$15,$14,$13,$12,$11,$10\n    .byte $0f,$0e,$0d,$0c,$0b,$0a,$09,$08\n    .byte $07,$06,$05,$04,$03,$02,$01,$00\nwave_x:\n    .byte $00,$01,$02,$03,$04,$05,$06,$07,$08,$09,$0a,$0b,$0c,$0d,$0e,$0f\n    .byte $0f,$0e,$0d,$0c,$0b,$0a,$09,$08,$07,$06,$05,$04,$03,$02,$01,$00\n    .byte $00,$01,$02,$03,$04,$05,$06,$07\n\n.incbin c_joy_sprites, \"assets/sprites/c-joy.spr\"\n.include \"assets/sprites/c-joy.inc\"\n.incbin bumps_chars, \"assets/chars/bumps.chr\"\n.include \"assets/chars/bumps.inc\"\n",
    "selectedEntryLabel": "init"
  },
