    {
      "path": "main.c",
      "name": "main.c",
      "kind": "source",
      "source": "/*\n * Web64 IDE Example\n * Name: C Screen Memory\n * Description: Fills C64 screen RAM and color RAM using Web64 C loops.\n */\n\n#include <stdint.h>\n\nuint8_t index = 0;\n\nvoid main(void) {\n    *(uint8_t*)0xd020 = 0;\n    *(uint8_t*)0xd021 = 6;\n    index = 0;\n    while (index != 250) {\n        *(uint8_t*)(0x0400 + index) = 1;\n        *(uint8_t*)(0x04fa + index) = 2;\n        *(uint8_t*)(0xd800 + index) = 1;\n        *(uint8_t*)(0xd8fa + index) = 7;\n        index++;\n    }\n    while (1) { }\n}\n"
    }
  ]
