    {
      "path": "game.h",
      "name": "game.h",
      "kind": "source",
      "source": "#ifndef WEB64_C_SPRITE_JOY_GAME_H\n#define WEB64_C_SPRITE_JOY_GAME_H\n\n#include <stdint.h>\n\ntypedef struct {\n    uint8_t x;\n    uint8_t y;\n} player_xy;\n\nvoid setup_video(void);\nvoid copy_sprite_data(void);\nvoid setup_sprite(void);\nvoid wait_frame(void);\nvoid poll_joystick(void);\nvoid move_player(void);\nvoid position_sprite(void);\nvoid animate_sprite(void);\nvoid main(void);\n\n#endif\n"
    },
    {
      "path": "main.c",
      "name": "main.c",
      "kind": "source",
      "source": "/*************************************\n* Web64 IDE Sprite + Joystick example\n* in C + inline assembly\n*************************************/\n\n#include <stdint.h>\n#include <c64.h>\n#include <stdbool.h>\n#include <web64.h>\n#include \"game.h\"\n\n#define SPRITE_POINTER 0xc0\n#define SPRITE_COPY_TARGET 0x3000\n\nplayer_xy player = { 120, 100 };\nuint8_t joy2 = JOY_RELEASED_MASK;\nuint8_t moving = 0;\nuint8_t sprite_color = VIC_COLOR_YELLOW;\nuint8_t frame = 0;\nuint8_t anim_delay = 0;\nuint8_t sprite_pointer = SPRITE_POINTER;\n\nvoid setup_video(void) {\n    *(uint8_t*)CIA1_DDRA = 0;\n    *(uint8_t*)CIA1_DDRB = 0;\n    *(uint8_t*)VIC_BORDER = VIC_COLOR_BLACK;\n    *(uint8_t*)VIC_BACKGROUND = VIC_COLOR_BLUE;\n}\n\nvoid chg_bg(void) {\n\t*(uint8_t*)VIC_BORDER = VIC_COLOR_YELLOW;\n    *(uint8_t*)VIC_BACKGROUND = VIC_COLOR_BLUE;\n}\n\nvoid copy_sprite_data(void) {\n\tasm volatile(\n        \"    ldx #0\\n\"\n        \"copy_sprite_byte:\\n\"\n        \"    lda c_joy_sprites,x\\n\"\n        \"    sta $3000,x\\n\"\n        \"    inx\\n\"\n        \"    bne copy_sprite_byte\\n\"\n\t);\n\treturn();\n    asm volatile(\n\t\t\"c_joy_sprites:\\n\"\n\t    \".incbin \\\"assets/sprites/c-joy.spr\\\"\\n\"\n    );\n\n}\n\nvoid setup_sprite(void) {\n    *(uint8_t*)VIC_SPRITE_POINTER_BASE = SPRITE_POINTER;\n    *(uint8_t*)VIC_SPRITE_ENABLE = 1;\n    *(uint8_t*)VIC_SPRITE_MULTICOLOR = 1;\n    *(uint8_t*)VIC_SPRITE_MULTICOLOR0 = VIC_COLOR_GREEN;\n    *(uint8_t*)VIC_SPRITE_MULTICOLOR1 = VIC_COLOR_DARK_GRAY;\n    *(uint8_t*)VIC_SPRITE0_COLOR = sprite_color;\n}\n\nvoid wait_frame(void) {\n    asm volatile(\n        \"wait_not_250:\\n\"\n        \"    lda $d012\\n\"\n        \"    cmp #250\\n\"\n        \"    beq wait_not_250\\n\"\n        \"wait_250:\\n\"\n        \"    lda $d012\\n\"\n        \"    cmp #250\\n\"\n        \"    bne wait_250\\n\"\n    );\n}\n\nvoid poll_joystick(void) {\n    joy2 = *(uint8_t*)JOYPORT_2;\n}\n\nvoid move_player(void) {\n    moving = 0;\n    sprite_color = VIC_COLOR_YELLOW;\n    if (!(joy2 & JOY_LEFT)) { player.x--; moving++; }\n    if (!(joy2 & JOY_RIGHT)) { player.x++; moving++; }\n    if (!(joy2 & JOY_UP)) { player.y--; moving++; }\n    if (!(joy2 & JOY_DOWN)) { player.y++; moving++; }\n    if (!(joy2 & JOY_FIRE)) { sprite_color = VIC_COLOR_RED; }\n}\n\nvoid position_sprite(void) {\n    *(uint8_t*)VIC_SPRITE0_X = player.x;\n    *(uint8_t*)VIC_SPRITE0_Y = player.y;\n    *(uint8_t*)VIC_SPRITE_ENABLE = 1;\n    *(uint8_t*)VIC_SPRITE0_COLOR = sprite_color;\n}\n\nvoid animate_sprite(void) {\n    if (!(moving & 0xff)) { frame = 0; anim_delay = 0; }\n    if (moving & 0xff) { anim_delay++; }\n    if (anim_delay & 8) { anim_delay = 0; frame++; }\n    if (frame & 4) { frame = 0; }\n    sprite_pointer = SPRITE_POINTER;\n    if (frame & 1) { sprite_pointer++; }\n    if (frame & 2) { sprite_pointer++; sprite_pointer++; }\n    *(uint8_t*)VIC_SPRITE_POINTER_BASE = sprite_pointer;\n}\n\nvoid main(void) {\n    setup_video();\n    copy_sprite_data();\n    setup_sprite();\n\tclrscr();\n\tputs(\"hello world!\\n\");\n    while (true) { \n        wait_frame();\n        poll_joystick();\n        move_player();\n        position_sprite();\n        animate_sprite();\n\t}\n}\n"
    },
    {
      "path": "main-inline-asm-reference.note",
      "name": "main-inline-asm-reference.note",
      "kind": "asset",
      "source": "#include \"game.h\"\n\nvoid main(void) {\n    asm volatile(\n        \"BORDER      = $d020\\n\"\n        \"BACKGROUND  = $d021\\n\"\n        \"RASTER      = $d012\\n\"\n        \"SPR0_X      = $d000\\n\"\n        \"SPR0_Y      = $d001\\n\"\n        \"SPR_ENABLE  = $d015\\n\"\n        \"SPR_MC      = $d01c\\n\"\n        \"SPR_PTR0    = $07f8\\n\"\n        \"SPR_MC0     = $d025\\n\"\n        \"SPR_MC1     = $d026\\n\"\n        \"SPR_COLOR0  = $d027\\n\"\n        \"JOY2        = $dc00\\n\"\n        \"CIA1_DDRA   = $dc02\\n\"\n        \"CIA1_DDRB   = $dc03\\n\"\n        \"    sei\\n\"\n        \"    lda #0\\n\"\n        \"    sta CIA1_DDRA\\n\"\n        \"    sta CIA1_DDRB\\n\"\n        \"    sta BORDER\\n\"\n        \"    lda #6\\n\"\n        \"    sta BACKGROUND\\n\"\n        \"    ldx #0\\n\"\n        \"copy_sprite_byte_inline:\\n\"\n        \"    lda c_joy_sprites,x\\n\"\n        \"    sta $3000,x\\n\"\n        \"    inx\\n\"\n        \"    bne copy_sprite_byte_inline\\n\"\n        \"    lda #$c0\\n\"\n        \"    sta SPR_PTR0\\n\"\n        \"    lda #%00000001\\n\"\n        \"    sta SPR_ENABLE\\n\"\n        \"    sta SPR_MC\\n\"\n        \"    lda #c_joy_multicolor_1\\n\"\n        \"    sta SPR_MC0\\n\"\n        \"    lda #c_joy_multicolor_2\\n\"\n        \"    sta SPR_MC1\\n\"\n        \"    lda sprite_color_inline\\n\"\n        \"    sta SPR_COLOR0\\n\"\n        \"inline_main_loop:\\n\"\n        \"    jsr wait_frame_inline\\n\"\n        \"    jsr read_joy2_inline\\n\"\n        \"    jsr move_player_inline\\n\"\n        \"    jsr position_sprite_inline\\n\"\n        \"    jsr animate_sprite_inline\\n\"\n        \"    jmp inline_main_loop\\n\"\n        \"wait_frame_inline:\\n\"\n        \"wait_not_250_inline:\\n\"\n        \"    lda RASTER\\n\"\n        \"    cmp #250\\n\"\n        \"    beq wait_not_250_inline\\n\"\n        \"wait_250_inline:\\n\"\n        \"    lda RASTER\\n\"\n        \"    cmp #250\\n\"\n        \"    bne wait_250_inline\\n\"\n        \"    rts\\n\"\n        \"read_joy2_inline:\\n\"\n        \"    lda JOY2\\n\"\n        \"    sta joy2_inline\\n\"\n        \"    rts\\n\"\n        \"move_player_inline:\\n\"\n        \"    lda #0\\n\"\n        \"    sta moving_inline\\n\"\n        \"    lda joy2_inline\\n\"\n        \"    and #4\\n\"\n        \"    bne skip_left_inline\\n\"\n        \"    dec player_x_inline\\n\"\n        \"    inc moving_inline\\n\"\n        \"skip_left_inline:\\n\"\n        \"    lda joy2_inline\\n\"\n        \"    and #8\\n\"\n        \"    bne skip_right_inline\\n\"\n        \"    inc player_x_inline\\n\"\n        \"    inc moving_inline\\n\"\n        \"skip_right_inline:\\n\"\n        \"    lda joy2_inline\\n\"\n        \"    and #1\\n\"\n        \"    bne skip_up_inline\\n\"\n        \"    dec player_y_inline\\n\"\n        \"    inc moving_inline\\n\"\n        \"skip_up_inline:\\n\"\n        \"    lda joy2_inline\\n\"\n        \"    and #2\\n\"\n        \"    bne skip_down_inline\\n\"\n        \"    inc player_y_inline\\n\"\n        \"    inc moving_inline\\n\"\n        \"skip_down_inline:\\n\"\n        \"    lda joy2_inline\\n\"\n        \"    and #16\\n\"\n        \"    bne skip_fire_inline\\n\"\n        \"    lda #2\\n\"\n        \"    sta sprite_color_inline\\n\"\n        \"skip_fire_inline:\\n\"\n        \"    rts\\n\"\n        \"position_sprite_inline:\\n\"\n        \"    lda player_x_inline\\n\"\n        \"    sta SPR0_X\\n\"\n        \"    lda player_y_inline\\n\"\n        \"    sta SPR0_Y\\n\"\n        \"    lda #%00000001\\n\"\n        \"    sta SPR_ENABLE\\n\"\n        \"    lda sprite_color_inline\\n\"\n        \"    sta SPR_COLOR0\\n\"\n        \"    rts\\n\"\n        \"animate_sprite_inline:\\n\"\n        \"    lda moving_inline\\n\"\n        \"    beq idle_frame_inline\\n\"\n        \"    inc anim_delay_inline\\n\"\n        \"    lda anim_delay_inline\\n\"\n        \"    cmp #6\\n\"\n        \"    bcc done_anim_inline\\n\"\n        \"    lda #0\\n\"\n        \"    sta anim_delay_inline\\n\"\n        \"    inc frame_inline\\n\"\n        \"    lda frame_inline\\n\"\n        \"    cmp #4\\n\"\n        \"    bcc set_frame_inline\\n\"\n        \"    lda #0\\n\"\n        \"    sta frame_inline\\n\"\n        \"set_frame_inline:\\n\"\n        \"    lda #$c0\\n\"\n        \"    clc\\n\"\n        \"    adc frame_inline\\n\"\n        \"    sta SPR_PTR0\\n\"\n        \"done_anim_inline:\\n\"\n        \"    rts\\n\"\n        \"idle_frame_inline:\\n\"\n        \"    lda #0\\n\"\n        \"    sta frame_inline\\n\"\n        \"    lda #$c0\\n\"\n        \"    sta SPR_PTR0\\n\"\n        \"    rts\\n\"\n        \"player_x_inline: .byte 120\\n\"\n        \"player_y_inline: .byte 100\\n\"\n        \"sprite_color_inline: .byte 7\\n\"\n        \"joy2_inline: .byte $ff\\n\"\n        \"moving_inline: .byte 0\\n\"\n        \"frame_inline: .byte 0\\n\"\n        \"anim_delay_inline: .byte 0\\n\"\n        \".incbin c_joy_sprites, \\\"assets/sprites/c-joy.spr\\\"\\n\"\n    );\n    return;\n}\n"
    },
