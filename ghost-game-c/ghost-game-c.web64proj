      "path": "game.h",
      "name": "game.h",
      "kind": "source",
      "source": "#ifndef SPRITE_JOY_SID_BUMPS_C_GAME_H\n#define SPRITE_JOY_SID_BUMPS_C_GAME_H\n\nvoid setup_video(void);\nvoid copy_charset(void);\nvoid copy_sprites(void);\nvoid clear_screen(void);\nvoid paint_scene(void);\nvoid sid_init(void);\nvoid sprite_init(void);\nvoid wait_frame(void);\nvoid play_sid(void);\nvoid read_joy(void);\nvoid update_x_velocity(void);\nvoid update_y_velocity(void);\nvoid apply_motion(void);\nvoid animate_ghost(void);\nvoid position_sprite(void);\nvoid pulse_scene(void);\nvoid asm_draw_score(void);\n\n#endif"
    },
    {
      "path": "main.c",
      "name": "main.c",
      "kind": "source",
      "source": "/*\n * Web64 IDE Example\n * Name: Sprite Joy SID Bumps C\n * Description: C control loop with fixed-point sprite acceleration and C-callable assembly assets/SID.\n */\n\n#include <stdint.h>\n#include <c64.h>\n#include \"game.h\"\n\n#define SPRITE_POINTER 0xc0\n#define COIN_POINTER 0xc4\n#define SCREEN_RAM 0x0400\n#define COLOR_RAM 0xd800\n#define VIC_SPRITE1_X 0xd002\n#define VIC_SPRITE1_Y 0xd003\n#define VIC_SPRITE1_COLOR 0xd028\n#define SCORE_ROW 0\n#define SCORE_COL 1\n#define SCORE_FILL 0x1a\n#define SCORE_COLOR VIC_COLOR_YELLOW\n\nint16_t player_x = 5120;\nint16_t player_y = 3584;\nint16_t player_dx = 0;\nint16_t player_dy = 0;\nuint8_t joy_now = JOY_RELEASED_MASK;\nuint8_t frame = 0;\nuint8_t anim_delay = 0;\nuint16_t coin_x = 184;\nuint8_t coin_y = 96;\nuint8_t coin_frame = 0;\nuint8_t coin_delay = 0;\nuint8_t coin_forward = 1;\nuint8_t rng = 73;\nuint8_t score = 0;\nuint16_t screen_offset = 0;\n\nvoid read_joy(void) {\n    joy_now = *(uint8_t*)JOYPORT_2;\n}\n\nvoid update_x_velocity(void) {\n    if ((joy_now & JOY_LEFT) == 0) {\n        player_dx = player_dx - 6;\n        if (player_dx < -128) {\n            player_dx = -128;\n        }\n        return;\n    }\n    if ((joy_now & JOY_RIGHT) == 0) {\n        player_dx = player_dx + 6;\n        if (player_dx > 128) {\n            player_dx = 128;\n        }\n        return;\n    }\n    if (player_dx > 0) {\n        if (player_dx <= 4) {\n            player_dx = 0;\n        } else {\n            player_dx = player_dx - 4;\n        }\n        return;\n    }\n    if (player_dx < 0) {\n        if (player_dx >= -4) {\n            player_dx = 0;\n        } else {\n            player_dx = player_dx + 4;\n        }\n    }\n}\n\nvoid update_y_velocity(void) {\n    if ((joy_now & JOY_UP) == 0) {\n        player_dy = player_dy - 5;\n        if (player_dy < -96) {\n            player_dy = -96;\n        }\n        return;\n    }\n    if ((joy_now & JOY_DOWN) == 0) {\n        player_dy = player_dy + 5;\n        if (player_dy > 96) {\n            player_dy = 96;\n        }\n        return;\n    }\n    if (player_dy > 0) {\n        if (player_dy <= 4) {\n            player_dy = 0;\n        } else {\n            player_dy = player_dy - 4;\n        }\n        return;\n    }\n    if (player_dy < 0) {\n        if (player_dy >= -4) {\n            player_dy = 0;\n        } else {\n            player_dy = player_dy + 4;\n        }\n    }\n}\n\nvoid apply_motion(void) {\n    player_x = player_x + player_dx;\n    if (player_x < 0) {\n        player_x = player_x + 10240;\n    }\n    if (player_x >= 10240) {\n        player_x = player_x - 10240;\n    }\n\n    player_y = player_y + player_dy;\n    if (player_y < 1600) {\n        player_y = 1600;\n        player_dy = 0;\n    }\n    if (player_y > 7008) {\n        player_y = 7008;\n        player_dy = 0;\n    }\n}\n\nvoid animate_ghost(void) {\n    if ((player_dx == 0) && (player_dy == 0)) {\n        frame = 0;\n        anim_delay = 0;\n        *(uint8_t*)VIC_SPRITE_POINTER_BASE = SPRITE_POINTER;\n        return;\n    }\n\n    anim_delay = anim_delay + 1;\n    if (anim_delay < 5) {\n        return;\n    }\n    anim_delay = 0;\n    frame = frame + 1;\n    if (frame >= 4) {\n        frame = 0;\n    }\n    *(uint8_t*)VIC_SPRITE_POINTER_BASE = SPRITE_POINTER + frame;\n}\n\nvoid animate_coin(void) {\n    coin_delay = coin_delay + 1;\n    if (coin_delay < 2) {\n        return;\n    }\n    coin_delay = 0;\n\n    if (coin_forward != 0) {\n        coin_frame = coin_frame + 1;\n        if (coin_frame >= 8) {\n            coin_forward = 0;\n        }\n    } else {\n        coin_frame = coin_frame - 1;\n        if (coin_frame == 0) {\n            coin_forward = 1;\n        }\n    }\n    *(uint8_t*)(VIC_SPRITE_POINTER_BASE + 1) = COIN_POINTER + coin_frame;\n}\n\nvoid position_sprite(void) {\n    uint16_t sprite_x;\n    uint8_t x_msb;\n\n    sprite_x = (uint16_t)(player_x / 32);\n    *(uint8_t*)VIC_SPRITE0_X = (uint8_t)sprite_x;\n    *(uint8_t*)VIC_SPRITE0_Y = (uint8_t)(player_y / 32);\n\n    x_msb = *(uint8_t*)VIC_SPRITE_X_MSB;\n    if (sprite_x >= 256) {\n        x_msb = x_msb | 0x01;\n    } else {\n        x_msb = x_msb & 0xfe;\n    }\n    if (coin_x >= 256) {\n        x_msb = x_msb | 0x02;\n    } else {\n        x_msb = x_msb & 0xfd;\n    }\n    *(uint8_t*)VIC_SPRITE_X_MSB = x_msb;\n\n    *(uint8_t*)VIC_SPRITE1_X = (uint8_t)coin_x;\n    *(uint8_t*)VIC_SPRITE1_Y = coin_y;\n    *(uint8_t*)VIC_SPRITE1_COLOR = VIC_COLOR_YELLOW;\n\n    if ((joy_now & JOY_FIRE) == 0) {\n        *(uint8_t*)VIC_SPRITE0_COLOR = VIC_COLOR_RED;\n    } else {\n        *(uint8_t*)VIC_SPRITE0_COLOR = VIC_COLOR_WHITE;\n    }\n}\n\nuint8_t abs_diff8(uint8_t left, uint8_t right) {\n    if (left >= right) {\n        return left - right;\n    }\n    return right - left;\n}\n\nuint16_t screen_cell(uint8_t row, uint8_t col) {\n    screen_offset = col;\n    while (row != 0) {\n        screen_offset = screen_offset + 40;\n        row = row - 1;\n    }\n    return screen_offset;\n}\n\nvoid put_score_cell(uint8_t row, uint8_t col, uint8_t filled) {\n    uint16_t cell;\n    cell = screen_cell(row, col);\n    if (filled != 0) {\n        *(uint8_t*)(SCREEN_RAM + cell) = SCORE_FILL;\n    } else {\n        *(uint8_t*)(SCREEN_RAM + cell) = 0;\n    }\n    *(uint8_t*)(COLOR_RAM + cell) = SCORE_COLOR;\n}\n\nuint8_t digit_bit(uint8_t digit, uint8_t bit) {\n    if (digit == 0) return bit != 6;\n    if (digit == 1) return (bit == 2) || (bit == 5);\n    if (digit == 2) return (bit == 0) || (bit == 2) || (bit == 3) || (bit == 4) || (bit == 6);\n    if (digit == 3) return (bit == 0) || (bit == 2) || (bit == 3) || (bit == 5) || (bit == 6);\n    if (digit == 4) return (bit == 1) || (bit == 2) || (bit == 3) || (bit == 5);\n    if (digit == 5) return (bit == 0) || (bit == 1) || (bit == 3) || (bit == 5) || (bit == 6);\n    if (digit == 6) return (bit == 0) || (bit == 1) || (bit == 3) || (bit == 4) || (bit == 5) || (bit == 6);\n    if (digit == 7) return (bit == 0) || (bit == 2) || (bit == 5);\n    if (digit == 8) return 1;\n    return (bit == 0) || (bit == 1) || (bit == 2) || (bit == 3) || (bit == 5) || (bit == 6);\n}\n\nvoid draw_digit(uint8_t col, uint8_t digit) {\n    put_score_cell(SCORE_ROW, col + 0, digit_bit(digit, 0));\n    put_score_cell(SCORE_ROW, col + 1, digit_bit(digit, 0));\n    put_score_cell(SCORE_ROW, col + 2, digit_bit(digit, 0));\n    put_score_cell(SCORE_ROW + 1, col + 0, digit_bit(digit, 1));\n    put_score_cell(SCORE_ROW + 1, col + 1, 0);\n    put_score_cell(SCORE_ROW + 1, col + 2, digit_bit(digit, 2));\n    put_score_cell(SCORE_ROW + 2, col + 0, digit_bit(digit, 3));\n    put_score_cell(SCORE_ROW + 2, col + 1, digit_bit(digit, 3));\n    put_score_cell(SCORE_ROW + 2, col + 2, digit_bit(digit, 3));\n    put_score_cell(SCORE_ROW + 3, col + 0, digit_bit(digit, 4));\n    put_score_cell(SCORE_ROW + 3, col + 1, 0);\n    put_score_cell(SCORE_ROW + 3, col + 2, digit_bit(digit, 5));\n    put_score_cell(SCORE_ROW + 4, col + 0, digit_bit(digit, 6));\n    put_score_cell(SCORE_ROW + 4, col + 1, digit_bit(digit, 6));\n    put_score_cell(SCORE_ROW + 4, col + 2, digit_bit(digit, 6));\n}\n\nvoid draw_score(void) {\n    uint8_t tens;\n    uint8_t ones;\n    tens = score / 10;\n    ones = score;\n    while (ones >= 10) {\n        ones = ones - 10;\n    }\n    draw_digit(SCORE_COL, tens);\n    draw_digit(SCORE_COL + 4, ones);\n}\n\nvoid spawn_coin(void) {\n    uint8_t y_seed;\n    uint16_t coin_y_candidate;\n    rng = rng + 73 + (uint8_t)(player_x / 32) + (uint8_t)(player_y / 32) + score;\n    coin_x = 24 + rng;\n    y_seed = rng + frame + score;\n    coin_y_candidate = 58 + (uint16_t)y_seed;\n    while (coin_y_candidate > 210) {\n        coin_y_candidate = coin_y_candidate - 153;\n    }\n    coin_y = (uint8_t)coin_y_candidate;\n    coin_frame = 0;\n    coin_delay = 0;\n    coin_forward = 1;\n    *(uint8_t*)(VIC_SPRITE_POINTER_BASE + 1) = COIN_POINTER;\n    position_sprite();\n}\n\nvoid collect_coin(void) {\n    uint16_t sprite_x;\n    uint16_t x_gap;\n    uint8_t sprite_y;\n    sprite_x = (uint16_t)(player_x / 32);\n    sprite_y = (uint8_t)(player_y / 32);\n    if (sprite_x >= coin_x) {\n        x_gap = sprite_x - coin_x;\n    } else {\n        x_gap = coin_x - sprite_x;\n    }\n    if (x_gap >= 20) {\n        return;\n    }\n    if (abs_diff8(sprite_y, coin_y) >= 18) {\n        return;\n    }\n    score = score + 1;\n    if (score >= 100) {\n        score = 0;\n    }\n    asm_draw_score();\n    spawn_coin();\n}\n\nvoid main(void) {\n    setup_video();\n    copy_charset();\n    copy_sprites();\n    clear_screen();\n    paint_scene();\n    sid_init();\n    sprite_init();\n    spawn_coin();\n    position_sprite();\n    asm_draw_score();\n\n    while (1) {\n\t\t//*(uint8_t*)VIC_BORDER = VIC_COLOR_GREEN;\n        wait_frame();\n        //*(uint8_t*)VIC_BORDER = VIC_COLOR_RED;\n        play_sid();\n        read_joy();\n        update_x_velocity();\n        update_y_velocity();\n        apply_motion();\n        animate_ghost();\n        animate_coin();\n        position_sprite();\n        collect_coin();\n        pulse_scene();\n        asm_draw_score();\n    \n    }\n}"
    }
  ]
}