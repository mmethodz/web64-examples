  "main": {
    "fileName": "hybrid-asm-uses-c-data.asm",
    "origin": "$c000",
    "source": "; Web64 IDE Example\n; Name: Hybrid ASM Uses C Data\n; Description: Assembly start code reads a global variable emitted by Web64 C.\n\n* = $c000\n\ninit:\n    sei\n    lda _border_from_c\n    sta $d020\n    lda #0\n    sta $d021\nloop:\n    jmp loop\n",
    "selectedEntryLabel": "init"
  },
  "c": {
    "enabled": true,
    "dialect": "web64-c-v0.1",
    "entry": "main.c",
    "includePaths": [
      "include",
