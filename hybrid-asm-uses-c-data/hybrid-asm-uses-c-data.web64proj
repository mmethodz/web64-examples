  "files": [
    {
      "path": "main.c",
      "name": "main.c",
      "kind": "source",
      "source": "/*\n * Web64 IDE Example\n * Name: Hybrid ASM Uses C Data\n * Description: Declares a C global consumed by the assembly entry point.\n */\n\n#include <stdint.h>\n\nuint8_t border_from_c = 4;\n\nvoid main(void) {\n    border_from_c = 4;\n}\n"
    }
  ]
